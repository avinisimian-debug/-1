# =============================================================================
# Staz AI — Production environment variables (safe template — no real secrets)
# =============================================================================
# Copy each NAME=VALUE pair into Vercel:
#   Project → Settings → Environment Variables → Add / Import
# Apply to: Production + Preview. Redeploy after changes.
#
# Local dev: copy to `.env.local` and fill in real values.
# =============================================================================

# OpenAI API key — Whisper speech-to-text fallback + GPT summaries, action items, chat.
# Get it: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Vercel Blob read/write token — stores uploaded audio/video and meeting recordings.
# Required for files over ~4 MB (direct multipart upload bypasses serverless body limit).
# Get it: Vercel Dashboard → Storage → Blob → Connect to project
BLOB_READ_WRITE_TOKEN=

# Recall.ai API key — meeting bot joins Zoom / Google Meet / Teams and records the call.
# Get it: https://www.recall.ai/
# Webhook URL (register in Recall): https://YOUR_DOMAIN/api/webhooks/recall?token=YOUR_CRON_SECRET
RECALL_AI_API_KEY=

# Resend API key — sends post-meeting digest emails (summary + action items) to attendees.
# Get it: https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address in Resend (must match a domain you verified in Resend).
# Example: Staz AI <noreply@1stazai.com>
RESEND_FROM_EMAIL=

# Shared secret for cron jobs and webhook authentication (Bearer / ?token=).
# Protects GET /api/cron/live-bots, /api/live/dispatch, and Recall webhook ?token=.
# Generate: openssl rand -base64 32
CRON_SECRET=

# PayPal REST API client ID — server-side orders, subscriptions, and webhooks.
# Get it: PayPal Developer Dashboard → Apps & Credentials → your app → Client ID
PAYPAL_CLIENT_ID=

# PayPal REST API secret — keep server-only; never expose in client code.
# Get it: same PayPal app → Secret (show once, then store here)
PAYPAL_CLIENT_SECRET=

# PayPal environment: use "live" for production charges, "sandbox" for testing.
PAYPAL_MODE=live

# PayPal client ID exposed to the browser for the checkout button (same value as PAYPAL_CLIENT_ID).
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Optional — only if you created plans manually in PayPal (otherwise auto-created):
# PAYPAL_PRODUCT_ID=
# PAYPAL_LAUNCH_PLAN_ID=
# PAYPAL_REGULAR_PLAN_ID=

# =============================================================================
# Staz AI — תבנית משתני סביבה (ללא מפתחות אמיתיים — בטוח ל-GitHub)
# =============================================================================
# העתיקו ל-.env.local לפיתוח מקומי, או ל-.env.vercel.import לפרודקשן.
# לפרודקשן: מלאו ערכים ב-.env.vercel.import וייבאו ב-Vercel Dashboard.
# =============================================================================

# --- חובה — תמלול ו-AI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- חובה — התחברות (NextAuth) ---
# ליצירת סוד: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
AUTH_URL=https://1stazai.com

# --- חובה בפרודקשן — אחסון + העלאות גדולות (וידאו Zoom / הרצאות) ---
# Vercel → Storage → Blob → Connect to project → BLOB_READ_WRITE_TOKEN
# נדרש לקבצים מעל ~4.5MB ולהעלאות וידאו (multipart/chunked).
BLOB_READ_WRITE_TOKEN=

# Live Hub (Zoom / Google Meet) — לא דורש API keys.
# משתמשים מדביקים קישורי פגישה; Join / Calendar / Reminders עובדים בצד הלקוח.

# --- Google OAuth ---
# Redirect: https://1stazai.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# --- PayPal ---
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=live
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_LAUNCH_PLAN_ID=
# PAYPAL_REGULAR_PLAN_ID=
# PAYPAL_PRODUCT_ID=

# --- מנהל + Pro grants ---
# avi.nisimian@gmail.com is always admin in code (PRIMARY_ADMIN_EMAIL).
# Set ADMIN_EMAIL on Vercel to the same address (or extra admins via ADMIN_EMAILS).
ADMIN_EMAIL=avi.nisimian@gmail.com
# ADMIN_EMAILS=other-admin@example.com
PRO_GRANTED_EMAILS=avi.nisimian@gmail.com

# --- AssemblyAI — diarization ב-Pro (אופציונלי) ---
ASSEMBLYAI_API_KEY=

# --- SEO (אופציונלי) ---
NEXT_PUBLIC_SITE_URL=https://1stazai.com
# GOOGLE_SITE_VERIFICATION=

# --- Google AdSense ---
# Publisher: ca-pub-1517251000751283 (script already in layout)
# Create a Display ad unit in AdSense → copy the data-ad-slot number here:
# NEXT_PUBLIC_ADSENSE_SLOT=1234567890
# Also turn on Auto ads in AdSense for 1stazai.com
# Verify https://1stazai.com/ads.txt is reachable after deploy

# --- מתקדם ---
# FFMPEG_BIN=
# SKIP_ENV_VALIDATION=1
